node_modules/
main.js
*.log
.DS_Store

# Local dev tools / specs — contain absolute paths and are not part of the
# distributable plugin. Kept locally only.
scripts/
# Ignore docs/ contents (local notes w/ absolute paths) EXCEPT the
# version-controlled design specs under docs/superpowers/. Git can't re-include
# a path whose parent dir is excluded, so exclude docs/* (one level) not docs/.
docs/*
!docs/superpowers/
